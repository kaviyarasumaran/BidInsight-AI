APP_NAME=BidInsight API
ENV=dev
LOG_LEVEL=info
API_PREFIX=/api

# Postgres (metadata + audit)
POSTGRES_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/bidinsight
POSTGRES_REQUIRED=false

# MongoDB (extraction/evidence docs)
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=bidinsight

# Redis (job queue + status)
REDIS_DSN=redis://localhost:6379/0
QUEUE_BACKEND=local
REDIS_REQUIRED=false

# Local LLM provider (replaceable)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:1234
OLLAMA_MODEL=llama3.1

# LM Studio (OpenAI-compatible)
LMSTUDIO_BASE_URL=http://127.0.0.1:1234
LMSTUDIO_MODEL=local-model

# CORS
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Storage
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage
